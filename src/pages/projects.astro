---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout title="Projects — Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">PROJECTS</p>
      <h1>Things I've built.</h1>
      <p class="lead">
        A mix of commercial products, open source tools, and side experiments.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="margin-bottom: var(--gap-xl);">
        <p class="eyebrow">COMMERCIAL</p>
        <h2>Closed source.</h2>
      </div>
      <div class="grid-2">
        <ProjectCard
          title="Pigeonbook"
          subtitle="AI Accountant for Small Businesses"
          description="AI-powered accounting — making bookkeeping as simple as having a conversation."
          badge="Commercial"
          href="https://www.pigeonbook.co/"
        />
        <ProjectCard
          title="EV Charging Platform"
          subtitle="OCPP & OCPI-Compliant Charger Management"
          description="Pre-auth payment integration and real-time monitoring for building owners to monetize their EV charging infrastructure."
          badge="Commercial"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="margin-bottom: var(--gap-xl);">
        <p class="eyebrow">OPEN SOURCE</p>
        <h2>Built in public.</h2>
      </div>
      <div class="grid-2">
        <ProjectCard
          title="Lazyman TUI"
          subtitle="Local-First Terminal HTTP Client"
          description="A terminal UI for HTTP requests, inspired by lazygit. Local-first and keyboard-driven — requests stored as plain `.http` files in git."
          badge="Open Source"
          href="https://github.com/yinchuangsum/lazyman"
        />
        <ProjectCard
          title="3D Tour Style Catalogue"
          subtitle="Immersive WebGL Product Viewer"
          description="An interactive 3D catalogue for virtual tours and product browsing, built for real-time style exploration."
          badge="Open Source"
        />
      </div>
    </div>
  </section>
</BaseLayout>
