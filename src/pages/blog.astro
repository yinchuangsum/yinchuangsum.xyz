---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog — Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">TECHNICAL BLOG</p>
      <h1>Writing about what I build.</h1>
      <p class="lead">
        Deep dives on software architecture, engineering practices, and
        the tools that power modern products. All posts written by hand —
        no AI involved.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="search-bar">
        <input id="blog-search" class="input" type="text" placeholder="Search articles, topics, tags..." />
        <button id="blog-search-btn" class="btn btn-secondary">Search</button>
      </div>

      <div class="row-between" style="margin-bottom: var(--gap-lg);">
        <h2>Latest articles</h2>
        <div class="tag-cluster" id="blog-tags">
          <span class="tag" data-tag="ai">AI</span>
          <span class="tag" data-tag="architecture">Architecture</span>
          <span class="tag" data-tag="vue">Vue</span>
          <span class="tag" data-tag="kotlin">Kotlin</span>
          <span class="tag" data-tag="infra">Infra</span>
        </div>
      </div>

      <div id="blog-posts">
        <p class="meta" style="text-align: center; padding-block: var(--gap-2xl); font-size: 15px;">
          No posts yet.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sub-block" style="text-align: center;">
        <p class="meta" style="font-size: 15px; color: var(--muted);">
          Newsletter & RSS — coming soon.
        </p>
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById("blog-search");
    const searchBtn = document.getElementById("blog-search-btn");
    const tags = document.querySelectorAll("#blog-tags .tag");
    const postsContainer = document.getElementById("blog-posts");

    if (searchInput instanceof HTMLInputElement && postsContainer) {
      searchInput.addEventListener("input", () => updateResults(searchInput, postsContainer));
      searchBtn?.addEventListener("click", () => updateResults(searchInput, postsContainer));
    }

    tags.forEach((tag) => {
      tag.addEventListener("click", () => {
        const wasActive = tag.classList.contains("active");
        tags.forEach((t) => t.classList.remove("active"));
        if (!wasActive) tag.classList.add("active");
        if (searchInput instanceof HTMLInputElement && postsContainer) {
          updateResults(searchInput, postsContainer);
        }
      });
    });

    function updateResults(input: HTMLInputElement, container: HTMLElement) {
      const query = input.value.trim().toLowerCase();
      const activeTag = document.querySelector("#blog-tags .tag.active");
      const tag = activeTag?.getAttribute("data-tag") || "";
      container.innerHTML = `<p class="meta" style="text-align: center; padding-block: var(--gap-2xl); font-size: 15px;">` + (query || tag ? "No posts match your search." : "No posts yet.") + `</p>`;
    }
  </script>
</BaseLayout>
