---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogRow from "../components/LogRow.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog — Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">TECHNICAL BLOG</p>
      <h1>Writing about what I build.</h1>
      <p class="lead">
        Deep dives on software architecture, engineering practices, and
        the tools that power modern products.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="search-bar">
        <input id="blog-search" class="input" type="text" placeholder="Search articles, topics, tags..." />
        <button id="blog-search-btn" class="btn btn-secondary">Search</button>
      </div>

      <div class="row-between" style="margin-bottom: var(--gap-lg);">
        <h2>Latest articles</h2>
        <div class="tag-cluster" id="blog-tags">
          {allTags.map((tag) => (
            <span class="tag" data-tag={tag.toLowerCase()}>{tag}</span>
          ))}
        </div>
      </div>

      <div id="blog-posts">
        {posts.length > 0 ? (
          <>
            {posts.map((post) => (
              <LogRow
                date={post.data.date.toLocaleDateString("en-US", {
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })}
                title={post.data.title}
                description={post.data.description}
                tags={post.data.tags}
                readTime={post.data.readTime}
                href={`/blog/${post.id.replace(/\.(md|mdx)$/, "")}`}
              />
            ))}
            <p class="meta empty-state" style="display: none; text-align: center; padding-block: var(--gap-2xl); font-size: 15px;">
              No posts match your search.
            </p>
          </>
        ) : (
          <p class="meta" style="text-align: center; padding-block: var(--gap-2xl); font-size: 15px;">
            No posts yet.
          </p>
        )}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sub-block" style="text-align: center;">
        <p class="meta" style="font-size: 15px; color: var(--muted);">
          Newsletter & RSS — coming soon.
        </p>
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById("blog-search");
    const searchBtn = document.getElementById("blog-search-btn");
    const tags = document.querySelectorAll("#blog-tags .tag");
    const postsContainer = document.getElementById("blog-posts");
    const posts = postsContainer?.querySelectorAll(".log-row");

    function filterPosts() {
      const query = (searchInput instanceof HTMLInputElement ? searchInput.value : "").trim().toLowerCase();
      const activeTag = document.querySelector("#blog-tags .tag.active");
      const tag = activeTag?.getAttribute("data-tag")?.toLowerCase() || "";

      let visible = 0;
      posts?.forEach((post) => {
        const title = (post.querySelector("h3")?.textContent || "").toLowerCase();
        const desc = (post.querySelector("p")?.textContent || "").toLowerCase();
        const postTags = [...post.querySelectorAll(".tag")].map((t) => t.textContent.toLowerCase());

        const matchesQuery = !query || title.includes(query) || desc.includes(query) || postTags.some((t) => t.includes(query));
        const matchesTag = !tag || postTags.includes(tag);

        if (matchesQuery && matchesTag) {
          (post as HTMLElement).style.display = "";
          visible++;
        } else {
          (post as HTMLElement).style.display = "none";
        }
      });

      const empty = postsContainer?.querySelector(".empty-state");
      if (empty) {
        (empty as HTMLElement).style.display = visible === 0 ? "" : "none";
      }
    }

    searchInput?.addEventListener("input", filterPosts);
    searchBtn?.addEventListener("click", filterPosts);

    tags.forEach((tag) => {
      tag.addEventListener("click", () => {
        const wasActive = tag.classList.contains("active");
        tags.forEach((t) => t.classList.remove("active"));
        if (!wasActive) tag.classList.add("active");
        filterPosts();
      });
    });
  </script>
</BaseLayout>
