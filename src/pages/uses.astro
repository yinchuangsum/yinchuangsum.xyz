---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Uses — Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">TOOLS & SETUP</p>
      <h1>What I use to build.</h1>
      <p class="lead">
        The tools, systems, and ideas behind my work. I build across AI, IoT,
        and backend systems — this page evolves as my workflow changes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>AI & Research</h2>
        <ul class="uses-list">
          <li><strong>ChatGPT</strong> — Daily research, prototyping, and reasoning partner.</li>
          <li><strong>Gemini</strong> — Large-context analysis and comparison.</li>
          <li><strong>Deepseek</strong> — Cost-effective research queries.</li>
          <li><strong>Raycast AI</strong> — Quick daily AI tasks. <a href="https://raycast.com/?via=yin-chuang" target="_blank" rel="noopener" class="uses-ref">Referral</a></li>
          <li><strong>Opencode Go</strong> — Daily coding assistant. <a href="https://opencode.ai/go?ref=RDWB6J5NB6" target="_blank" rel="noopener" class="uses-ref">Referral</a></li>
          <li><strong>LangGraph</strong> — AI workflow orchestration in Python.</li>
          <li><strong>Hermes Agent + OMLX</strong> — Local AI agent experimentation.</li>
          <li><strong>Mastra</strong> — Currently evaluating.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>Development</h2>
        <ul class="uses-list">
          <li><strong>Java / Kotlin</strong> — Primary languages for long-lived backend systems.</li>
          <li><strong>Python</strong> — AI workflows, automation, and rapid experimentation.</li>
          <li><strong>TypeScript</strong> — Full-stack applications and developer tooling.</li>
          <li><strong>PostgreSQL</strong> — Default database unless requirements suggest otherwise.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>Editor & Terminal</h2>
        <ul class="uses-list">
          <li><strong>Neovim</strong> — Fast, keyboard-first editing (LazyVim).</li>
          <li><strong>Tmux</strong> — Persistent sessions across projects and machines.</li>
          <li><strong>zsh</strong> — Lightweight shell with zinit.</li>
          <li><strong>fzf</strong> — Fuzzy search for files, buffers, and history.</li>
          <li><strong>ripgrep</strong> — Fast code search.</li>
          <li><strong>lazygit</strong> — Git from the terminal without leaving flow.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>IoT & Edge Computing</h2>
        <ul class="uses-list">
          <li><strong>Home Assistant</strong> — Smart home automation hub.</li>
          <li><strong>Node-RED</strong> — Visual automation wiring integrated with Home Assistant.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>Infrastructure & Homelab</h2>
        <p class="lead">
          I self-host services for learning, experimentation, and reducing
          dependency on external platforms.
        </p>
        <ul class="uses-list">
          <li><strong>2x Mac Mini + Raspberry Pi</strong> — Homelab cluster.</li>
          <li><strong>Forgejo</strong> — Self-hosted Git and project management.</li>
          <li><strong>Portainer</strong> — Container management.</li>
          <li><strong>Uptime Kuma</strong> — Monitoring critical services.</li>
          <li><strong>Authentik</strong> — Identity and access management.</li>
          <li><strong>Paperless NG</strong> — Searchable document archive.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>Current Experiments</h2>
        <ul class="uses-list">
          <li>— Building software with AI as the primary collaborator</li>
          <li>— TUI-first developer tools</li>
          <li>— Zig for performance-critical systems</li>
          <li>— Local AI agents and autonomous workflows</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="uses-section">
        <h2>Philosophy</h2>
        <ul class="uses-list uses-principles">
          <li>— Automate repetitive work.</li>
          <li>— Build systems, not scripts.</li>
          <li>— Prefer boring technology for production.</li>
          <li>— Own critical infrastructure when practical.</li>
          <li>— Keep humans in the loop where trust matters.</li>
          <li>— Build things that still work when you're asleep.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
