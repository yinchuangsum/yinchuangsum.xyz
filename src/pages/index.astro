---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">YIN CHUANG SUM</p>
      <h1>Yin Chuang Sum.</h1>
      <p class="lead">
        Building AI-driven accounting software, writing about engineering, and
        sharing what I learn along the way.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/now">Start here</a>
        <a class="btn btn-secondary" href="/blog">Read the blog</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="text-align: center; margin-bottom: var(--gap-xl);">
        <h2>Four pages. One story.</h2>
      </div>
      <div class="page-grid">
        <a class="card page-card" href="/now">
          <span class="meta">Now</span>
          <h3>What I&rsquo;m doing</h3>
          <p>
            Current focus: AI accounting, LangGraph agents, and marathon
            training.
          </p>
        </a>
        <a class="card page-card" href="/blog">
          <span class="meta">Blog</span>
          <h3>Technical writing</h3>
          <p>
            Deep dives on architecture, Vue, Kotlin, and infrastructure.
          </p>
        </a>
        <a class="card page-card" href="/speaking">
          <span class="meta">Speaking</span>
          <h3>Talks &amp; events</h3>
          <p>
            Upcoming conferences and an archive of past presentations.
          </p>
        </a>
        <a class="card page-card" href="/uses">
          <span class="meta">Uses</span>
          <h3>Tools &amp; setup</h3>
          <p>
            Editor, dev stack, homelab, and hardware that powers the work.
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
