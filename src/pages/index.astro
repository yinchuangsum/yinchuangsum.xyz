---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout title="Yin Chuang Sum">
  <Hero
    eyebrow="FOUNDER • SOFTWARE ARCHITECT • MAKER"
    heading="Building Intelligent Systems"
    lead="I create AI-powered software, connected IoT solutions, and automation platforms that transform complex ideas into products people use every day."
    variant="split"
    imageSrc="/images/profile.jpg"
  >
    <Fragment slot="cta">
      <a class="btn btn-primary" href="/projects">Explore Projects</a>
      <a class="btn btn-ghost btn-arrow" href="/blog">Read My Thoughts</a>
    </Fragment>
  </Hero>

  <section class="section">
    <div class="container stack" style="gap: var(--gap-xl);">
      <div style="max-width: 36ch;">
        <p class="eyebrow">WHAT I'M DOING NOW</p>
        <h2>Current focus areas.</h2>
      </div>
      <div class="grid-3">
        <div class="now-card">
          <h3>AI-Driven Accounting</h3>
          <p>
            Building the next generation of accounting software powered by
            machine learning and autonomous agents that understand financial
            context.
          </p>
        </div>
        <div class="now-card">
          <h3>Autonomous Agents</h3>
          <p>
            Experimenting with LangGraph and multi-agent workflows to automate
            complex business processes end-to-end.
          </p>
        </div>
        <div class="now-card">
          <h3>Marathon Training</h3>
          <p>
            Currently training for the Berlin Marathon. 80km weeks, early
            mornings, and learning the hard way that discipline compounds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 36ch; margin-bottom: var(--gap-xl);">
        <p class="eyebrow">CONNECT</p>
        <h2>Find me elsewhere.</h2>
      </div>
      <div class="social-row">
        <a href="https://github.com/yinchuangsum" target="_blank" rel="noopener">
