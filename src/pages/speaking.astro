---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Speaking — Yin Chuang Sum">
  <section class="section hero">
    <div class="container hero-center">
      <p class="eyebrow">SPEAKING & EVENTS</p>
      <h1>Sharing what I learn.</h1>
      <p class="lead">
        Nothing scheduled yet. I'll post upcoming talks and past
        appearances here when they happen.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align: center; padding-block: var(--gap-2xl);">
      <p class="meta" style="font-size: 15px; color: var(--muted);">
        No upcoming or past events to show right now.
      </p>
    </div>
  </section>
</BaseLayout>
