---
export interface Props {
  title: string;
  description?: string;
}

import "../styles/global.css";

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Now" },
  { href: "/blog", label: "Blog" },
  { href: "/speaking", label: "Speaking" },
  { href: "/uses", label: "Uses" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description || "Personal website of Yin Chuang Sum — CTO & Founder"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Scope+One&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <header class="topnav">
      <div class="container topnav-inner">
        <a href="/" class="logo">Yin Chuang Sum</a>
        <nav>
          {navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={path === link.href ? "page" : undefined}
              class:list={{ active: path === link.href }}
            >{link.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer class="pagefoot">
      <div class="container row-between">
        <span>&copy; 2026 &middot; Yin Chuang Sum</span>
        <span class="meta">Built with care &middot; hello@yinchuangsum.xyz</span>
      </div>
    </footer>
  </body>
</html>
