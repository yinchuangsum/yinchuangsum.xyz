---
export interface Props {
  title: string;
  description?: string;
}

import "../styles/global.css";

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Now" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/speaking", label: "Speaking" },
  { href: "/uses", label: "Uses" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description || "Personal website of Yin Chuang Sum — CTO & Founder"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Scope+One&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script async src="https://tally.so/widgets/embed.js"></script>

  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <header class="topnav">
      <div class="container topnav-inner">
        <a href="/" class="logo">Yin Chuang Sum</a>
        <button class="hamburger" aria-label="Toggle navigation" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav id="mobile-nav">
          {navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={path === link.href ? "page" : undefined}
              class:list={{ active: path === link.href }}
            >{link.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <script>
      const button = document.querySelector(".hamburger");
      const nav = document.querySelector("#mobile-nav");
      if (button && nav) {
        button.addEventListener("click", () => {
          const open = button.getAttribute("aria-expanded") === "true";
          button.setAttribute("aria-expanded", String(!open));
          nav.classList.toggle("open");
          document.body.style.overflow = open ? "" : "hidden";
        });
        nav.addEventListener("click", (e) => {
          if (e.target instanceof Element && e.target.tagName === "A") {
            button.setAttribute("aria-expanded", "false");
            nav.classList.remove("open");
            document.body.style.overflow = "";
          }
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && nav.classList.contains("open")) {
            button.setAttribute("aria-expanded", "false");
            nav.classList.remove("open");
            document.body.style.overflow = "";
          }
        });
      }
    </script>

    <main id="content">
      <slot />
    </main>

    <footer class="pagefoot">
      <div class="container row-between">
        <span>&copy; 2026 &middot; Yin Chuang Sum</span>
        <span class="meta">Built with care &middot; <button
          class="btn btn-ghost btn-arrow feedback-trigger"
          data-tally-open="rjgKgX"
          data-tally-layout="modal"
          data-tally-width="480"
          data-tally-hide-title="1"
        >Drop me a note</button></span>
      </div>
    </footer>
  </body>
</html>
